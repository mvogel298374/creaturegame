#!/bin/sh
# Deterministic pre-commit gate: formatting + tests must pass before a commit lands.
#
# This is the hard, unskippable backstop for the *deterministic* checks. The LLM-side reviews — domain /
# Gen-1 fidelity (`requirements-review`) and technical + generation-seam architecture (`pr-review`) — run in
# the main session before commit; a shell hook can't launch a subagent, so the pieces work together.
#
# Enable once per clone:  git config core.hooksPath .githooks
# Bypass in a genuine emergency:  git commit --no-verify  (don't make a habit of it)

DOTNET="C:/Users/USER/.dotnet/dotnet.exe"

echo "[pre-commit] CSharpier format check..."
if ! "$DOTNET" csharpier check . ; then
  echo "[pre-commit] BLOCKED: code is not CSharpier-formatted. Run: dotnet csharpier format ." >&2
  exit 1
fi

# Only run the (slower) test suite when C# actually changed — pure docs/data commits stay fast.
if git diff --cached --name-only --diff-filter=ACM | grep -q '\.cs$'; then
  echo "[pre-commit] .cs changes staged — running the .NET test suite..."
  if ! "$DOTNET" test tests/creaturegame.Tests --nologo ; then
    echo "[pre-commit] BLOCKED: tests failed. Fix them before committing." >&2
    exit 1
  fi
else
  echo "[pre-commit] No .cs changes staged — skipping the test suite."
fi

echo "[pre-commit] OK."
