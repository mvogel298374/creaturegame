# Build output
bin/
obj/
/publish/

# Release build artifacts copied into wwwroot by build-release.ps1 / Dockerfile
# (the SPA is generated from ClientApp/, not source)
creaturegame.Web/wwwroot/index.html
creaturegame.Web/wwwroot/assets/

# .NET
*.user
*.suo
.vs/
.idea/

# SQLite databases (runtime-generated, use PokeApiConnector to regenerate).
# Exception: the three shipped Gen 1 data DBs are committed so CI / deploy has
# them without a network import step. Everything else matching *.db stays ignored.
*.db
*.sqlite
!/pokemon.db
!/moves.db
!/items.db
# WAL/shared-memory sidecars created while the DB is open (e.g. running the dev stack)
*.db-wal
*.db-shm

# Logs
*.log

# Claude Code local session settings (auto-generated per-session allow rules)
.claude/settings.local.json

# AI/MCP tool local config
.ai/

# NuGet
*.nupkg
packages/

# Node / React
node_modules/
dist/
.vite/

# Sprites — runtime-generated by PokeApiConnector; not source files
creaturegame.Web/wwwroot/sprites/

# Cries — runtime-generated by PokeApiConnector; not source files
creaturegame.Web/wwwroot/audio/

# Playwright (e2e) outputs
creaturegame.Web/ClientApp/test-results/
creaturegame.Web/ClientApp/playwright-report/
creaturegame.Web/ClientApp/blob-report/
creaturegame.Web/ClientApp/.playwright/

# Claude Code scheduled-task lock (runtime state, not source)
.claude/scheduled_tasks.lock
